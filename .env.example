# === Logging ===
# Cognee's default INFO level prints a structlog line for nearly every
# internal step, which drowns out our own print() output and can get
# truncated in some terminals on long runs. WARNING keeps only real
# problems + our own prints. Use INFO or DEBUG if you need to see what
# Cognee is doing internally (e.g. while debugging a new issue).
LOG_LEVEL=WARNING

# === Storage location (Windows path-length fix) ===
# Cognee defaults to storing its LanceDB files deep inside
# site-packages/cognee/.cognee_system and .data_storage. Combined with a
# venv nested under something like Desktop/Cognee/codegraph-memory/, the
# resulting file paths (which include nested UUID folders) blow past
# Windows' 260-character MAX_PATH limit and LanceDB fails with
# "os error 3: The system cannot find the path specified". Point both
# roots at a short path near the drive root instead, e.g.:
#   DATA_ROOT_DIRECTORY=C:\cg\data
#   SYSTEM_ROOT_DIRECTORY=C:\cg\system
# On macOS/Linux this isn't needed, but it's harmless to set anyway.
DATA_ROOT_DIRECTORY=C:\cg\data
SYSTEM_ROOT_DIRECTORY=C:\cg\system

# === Cognee's internal graph-extraction LLM ===
# Cognee has no native "groq" provider — it's wired here as a generic
# OpenAI-compatible "custom" endpoint pointed at Groq's API. This is the
# officially-documented shape for CUSTOM in this Cognee version (verified
# by reading get_llm_client.py / GenericAPIAdapter — it just passes
# api_key + api_base straight into litellm/instructor), but it has NOT
# been tested end-to-end against a live Groq key yet. Run
# `python memory/verify_setup.py` after filling this in, before building
# anything on top of it.
LLM_PROVIDER=custom
LLM_ENDPOINT=https://api.groq.com/openai/v1
# Pick any current Groq model: https://console.groq.com/docs/models
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=your-groq-api-key-here

# === Embeddings ===
# fastembed runs fully local (ONNX, downloads once from HuggingFace on
# first use) — no API key needed, keeps us to a single paid key (Groq).
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# === Groq — used directly by orchestrator.py for code-gen/fix calls ===
# (separate from Cognee's internal LLM above, even though it's the same
# provider — orchestrator.py calls Groq's SDK directly, it does not go
# through Cognee for this.)
GROQ_API_KEY=your-groq-api-key-here
